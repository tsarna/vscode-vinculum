{
  "name": "vscode-vinculum",
  "displayName": "Vinculum VCL",
  "description": "Syntax highlighting, snippets, and AI assistance for Vinculum Configuration Language (.vcl)",
  "version": "0.1.1",
  "publisher": "tsarna",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsarna/vscode-vinculum"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "vcl",
    "vinculum",
    "hcl",
    "configuration"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "vcl",
        "aliases": [
          "VCL",
          "Vinculum"
        ],
        "extensions": [
          ".vcl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vcl",
        "scopeName": "source.vcl",
        "path": "./syntaxes/vcl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "vcl",
        "path": "./snippets/vcl.json"
      }
    ],
    "commands": [
      {
        "command": "vinculum.askAI",
        "title": "Ask AI",
        "category": "Vinculum"
      },
      {
        "command": "vinculum.clearDocCache",
        "title": "Clear Documentation Cache",
        "category": "Vinculum"
      }
    ],
    "configuration": {
      "title": "Vinculum",
      "properties": {
        "vinculum.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Anthropic model to use for AI assistance"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "marked": "^17.0.5"
  }
}
